// --- Atributos base (sobrescritos pelo inimigo ao dropar) ---
quantidade = 1;       // Quantas souls isso vale
escala_base_inimigo = 1; // Escala do inimigo para ajuste visual
coletado = false;     // Trava para não coletar 2x

// --- Configurações Visuais ---
image_alpha = 1;      // Começa totalmente visível
fade_speed = 0.05;    // Velocidade que some (aprox. 20 frames para sumir)